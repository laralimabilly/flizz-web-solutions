---
import { Github, Linkedin } from 'lucide-react';
import { getYear } from '../utils/utils.ts';
---

<footer class="relative bg-night border-t border-line overflow-hidden">
  <!-- Giant watermark wordmark -->
  <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 pointer-events-none select-none" aria-hidden="true">
    <span class="font-display font-bold text-[10rem] md:text-[18rem] leading-none text-light/[0.03] tracking-tight">FLIZZ</span>
  </div>

  <div class="container mx-auto px-6 py-20 relative z-10">
    <div class="grid lg:grid-cols-4 gap-12">
      <!-- Brand Section -->
      <div class="lg:col-span-2 space-y-6">
        <img class="w-32" src="/images/Flizz_Logo_Light@300x.webp" alt="Flizz Web Solutions logo" width="128" height="46" loading="lazy" />

        <p class="text-muted text-lg max-w-md leading-relaxed">
          Creating lightning-fast, pixel-perfect websites that soar above the competition.
          Your digital transformation partner in Brazil and the US.
        </p>

        <div class="flex space-x-3">
          <a
            href="https://github.com/laralimabilly"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Flizz on GitHub"
            class="w-11 h-11 bg-surface rounded-full border border-line flex items-center justify-center hover:bg-accent hover:border-accent transition-all duration-300 group"
          >
            <Github className="w-5 h-5 text-light group-hover:text-night transition-colors duration-300" />
          </a>
          <a
            href="https://www.linkedin.com/company/flizz-web-solutions/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Flizz on LinkedIn"
            class="w-11 h-11 bg-surface rounded-full border border-line flex items-center justify-center hover:bg-accent hover:border-accent transition-all duration-300 group"
          >
            <Linkedin className="w-5 h-5 text-light group-hover:text-night transition-colors duration-300" />
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="space-y-6">
        <h2 class="font-mono text-xs uppercase tracking-[0.3em] text-accent">Navigate</h2>
        <nav class="space-y-3" aria-label="Footer navigation">
          <a href="#home" class="block text-light/70 hover:text-accent hover:translate-x-1 transition-all duration-300">Home</a>
          <a href="#solutions" class="block text-light/70 hover:text-accent hover:translate-x-1 transition-all duration-300">Solutions</a>
          <a href="#portfolio" class="block text-light/70 hover:text-accent hover:translate-x-1 transition-all duration-300">Portfolio</a>
          <a href="#contact" class="block text-light/70 hover:text-accent hover:translate-x-1 transition-all duration-300">Contact</a>
        </nav>
      </div>

      <!-- Services -->
      <div class="space-y-6">
        <h2 class="font-mono text-xs uppercase tracking-[0.3em] text-accent">Services</h2>
        <nav class="space-y-3" aria-label="Services">
          <a href="#solutions" class="block text-light/70 hover:text-accent hover:translate-x-1 transition-all duration-300">Web Design</a>
          <a href="#solutions" class="block text-light/70 hover:text-accent hover:translate-x-1 transition-all duration-300">Web Development</a>
          <a href="#solutions" class="block text-light/70 hover:text-accent hover:translate-x-1 transition-all duration-300">Mobile Apps</a>
          <a href="#solutions" class="block text-light/70 hover:text-accent hover:translate-x-1 transition-all duration-300">Deploy & Maintenance</a>
        </nav>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t border-line mt-16 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="text-muted text-sm font-mono">
          © {getYear()} Flizz Web Solutions. All rights reserved.
        </div>

        <div class="text-muted text-sm font-mono flex items-center gap-2">
          Made with <span class="text-accent">⚡</span> in Brazil
        </div>
      </div>
    </div>
  </div>
</footer>
