---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import ProjectDetail from '../../../components/ProjectDetail.astro';
import { projects, getProjectBySlug, localizeProject } from '../../../data/projects';
import { ui } from '../../../i18n/ui';

export function getStaticPaths() {
  return projects.map((project) => ({ params: { slug: project.slug } }));
}

const lang = 'pt';
const t = ui[lang];

const { slug } = Astro.params;
const source = getProjectBySlug(slug!);
if (!source) throw new Error(`Unknown project slug: ${slug}`);
const project = localizeProject(source, lang);

const metaTitle = `${t.projectDetail.caseStudyPrefix}: ${project.title}${t.meta.projectTitleSuffix}`;
const metaDescription = project.description;
const canonical = new URL(`/pt/portfolio/${project.slug}`, Astro.site).toString();

// Project-level structured data for richer search results.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: project.title,
  headline: `${t.projectDetail.caseStudyPrefix}: ${project.title}`,
  about: project.industry,
  dateCreated: project.year,
  url: canonical,
  description: project.description,
  keywords: [...project.services, ...project.techStack].join(', '),
  inLanguage: 'pt-BR',
  creator: { '@type': 'Organization', name: 'Flizz Web Solutions' },
};
---

<Layout title={metaTitle} description={metaDescription} lang={lang}>
  <Header lang={lang} />
  <ProjectDetail project={project} lang={lang} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Layout>
